rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Reusable functions for validation
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) 
        && request.resource.data.keys().hasAll(['email'])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.targetFootprint is number
        && request.resource.data.targetFootprint >= 0;
      allow update: if isOwner(userId)
        && (!request.resource.data.keys().hasAny(['targetFootprint'])
          || request.resource.data.targetFootprint is number)
        && (!request.resource.data.keys().hasAny(['email'])
          || (request.resource.data.email is string
            && request.resource.data.email.size() > 0));
    }
    
    match /activities/{activityId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId)
        && request.resource.data.co2Amount is number
        && request.resource.data.category is string
        && request.resource.data.co2Amount >= 0;
      allow update: if isOwner(resource.data.userId) 
        && isOwner(request.resource.data.userId);
    }
    
    match /dailySummaries/{summaryId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId)
        && request.resource.data.totalCo2 is number;
      allow update: if isOwner(resource.data.userId)
        && isOwner(request.resource.data.userId);
    }
  }
}
