    "firebase": "^10.12.2",
    "postcss": "^8.4.38",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^6.23.1",
    "recharts": "^2.12.7",
    "tailwindcss": "^3.4.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "6.4.6",
    "@testing-library/react": "16.0.0",
    "@testing-library/user-event": "14.5.2",
    "@types/google.maps": "^3.65.1",
    "@types/node": "^24.12.3",
